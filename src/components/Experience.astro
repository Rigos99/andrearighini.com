---
import type { Translation } from '../i18n';
import SectionLabel from './SectionLabel.astro';
import LogoBadge from './LogoBadge.astro';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section class="mb-16">
  <SectionLabel id="work" text={t.work.title} />
  <ul class="space-y-3">
    {
      t.work.items.map((item) => {
        const hasDesc = item.description && item.description.length > 0;
        const cardBase =
          'flex items-center gap-4 rounded-2xl border border-dashed border-[var(--color-line)] bg-white px-4 py-3.5 shadow-sm transition duration-300 ease-out sm:px-5';
        const cardInteractive =
          'cursor-pointer list-none hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:shadow-md [&::-webkit-details-marker]:hidden';

        return (
          <li>
            {hasDesc ? (
              <details class="group">
                <summary class={`${cardBase} ${cardInteractive}`}>
                  <LogoBadge slug={item.slug} />
                  <div class="min-w-0 flex-1">
                    <p class="truncate font-semibold text-[var(--color-ink)]">{item.org}</p>
                    <p class="truncate text-sm text-[var(--color-muted)]">{item.role}</p>
                  </div>
                  <span class="shrink-0 text-xs text-[var(--color-muted)] tabular-nums sm:text-sm">
                    {item.period}
                  </span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="shrink-0 text-[var(--color-muted)] transition-transform group-open:rotate-180"
                    aria-hidden="true"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </summary>
                <div class="mt-2 rounded-2xl border border-dashed border-[var(--color-line)] bg-white px-4 py-3.5 text-sm leading-relaxed text-[var(--color-ink)] sm:px-5 sm:text-base">
                  {item.description}
                </div>
              </details>
            ) : (
              <div class={cardBase}>
                <LogoBadge slug={item.slug} />
                <div class="min-w-0 flex-1">
                  <p class="truncate font-semibold text-[var(--color-ink)]">{item.org}</p>
                  <p class="truncate text-sm text-[var(--color-muted)]">{item.role}</p>
                </div>
                <span class="shrink-0 text-xs text-[var(--color-muted)] tabular-nums sm:text-sm">
                  {item.period}
                </span>
              </div>
            )}
          </li>
        );
      })
    }
  </ul>
</section>
