---
import type { Translation } from '../i18n';

interface Props {
  t: Translation;
  currentLang: 'it' | 'en';
}

const { t, currentLang } = Astro.props;

const navItems = [
  { href: '#about', label: t.nav.about },
  { href: '#work', label: t.nav.work },
  { href: '#education', label: t.nav.education },
  { href: '#contact', label: t.nav.contact },
];
---

<nav class="mb-12 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <ul class="flex flex-wrap items-center gap-1.5">
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="inline-block rounded-full border border-[var(--color-accent)] bg-white px-3 py-1.5 text-sm font-medium text-[var(--color-accent-dark)] hover:bg-[var(--color-accent-soft)] focus-visible:bg-[var(--color-accent-soft)] focus-visible:outline-none"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div
    class="inline-flex items-center self-end rounded-full border border-[var(--color-line)] bg-white p-0.5 text-xs font-semibold shadow-sm sm:self-auto"
    role="group"
    aria-label="Language switcher"
  >
    <a
      href="/"
      class={`rounded-full px-2.5 py-1 transition ${currentLang === 'it' ? 'bg-[var(--color-accent)] text-white' : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]'}`}
      aria-current={currentLang === 'it' ? 'page' : undefined}
    >
      IT
    </a>
    <a
      href="/en/"
      class={`rounded-full px-2.5 py-1 transition ${currentLang === 'en' ? 'bg-[var(--color-accent)] text-white' : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]'}`}
      aria-current={currentLang === 'en' ? 'page' : undefined}
    >
      EN
    </a>
  </div>
</nav>
