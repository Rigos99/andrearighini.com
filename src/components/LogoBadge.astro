---
interface Props {
  slug: string;
}

const { slug } = Astro.props;

type ImageLogo = { kind: 'image'; src: string };
type TextLogo = {
  kind: 'text';
  bg: string;
  fg: string;
  label: string;
  textClass?: string;
};

const logos: Record<string, ImageLogo | TextLogo> = {
  freelance: { kind: 'image', src: '/freelance.jpg' },
  serenis: { kind: 'image', src: '/serenis.jpg' },
  loqui: { kind: 'image', src: '/loqui.jpg' },
  'unibo-master': { kind: 'image', src: '/unibo.jpg' },
  'unibo-bachelor': { kind: 'image', src: '/unibo.jpg' },
  ucam: { kind: 'image', src: '/ucam.jpg' },
  scs: {
    kind: 'text',
    bg: '#0f172a',
    fg: '#facc15',
    label: 'SCS',
    textClass: 'text-[11px] font-bold',
  },
};

const fallback: TextLogo = {
  kind: 'text',
  bg: '#e5e7eb',
  fg: '#374151',
  label: '?',
};
const logo = logos[slug] ?? fallback;
---

{
  logo.kind === 'image' ? (
    <img
      src={logo.src}
      alt=""
      width="48"
      height="48"
      loading="lazy"
      class="h-12 w-12 shrink-0 rounded-xl object-cover shadow-sm ring-1 ring-black/5"
    />
  ) : (
    <div
      class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-xl shadow-sm ring-1 ring-black/5"
      style={`background-color: ${logo.bg};`}
    >
      <span class={logo.textClass ?? 'text-lg font-bold'} style={`color: ${logo.fg};`}>
        {logo.label}
      </span>
    </div>
  )
}
