---
import type { Translation } from '../i18n';
import SectionLabel from './SectionLabel.astro';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section class="mb-12">
  <SectionLabel id="about" text={t.about.title} />
  <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      t.about.items.map((item) => (
        <li class="flex items-center gap-3 rounded-2xl border border-[var(--color-line)] bg-white px-4 py-3.5 shadow-sm transition duration-300 ease-out hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:shadow-md sm:px-5">
          <span class="shrink-0 text-2xl leading-none">{item.icon}</span>
          <p class="text-sm leading-relaxed text-[var(--color-ink)] sm:text-base">
            {item.text}
          </p>
        </li>
      ))
    }
  </ul>
</section>
