---
interface Props {
  text: string;
  id?: string;
}

const { text, id } = Astro.props;
---

<div id={id} class="mb-6 scroll-mt-12">
  <span
    class="inline-block rounded-full bg-[var(--color-accent-soft)] px-3 py-1 text-xs font-semibold tracking-wide text-[var(--color-accent-dark)] uppercase"
  >
    {text}
  </span>
</div>
