---
import type { Translation } from '../i18n';

interface Props {
  t: Translation;
}

const { t } = Astro.props;

const photoClass =
  'relative flex h-40 w-40 items-center justify-center overflow-hidden rounded-3xl bg-gradient-to-br from-emerald-100 to-amber-100 shadow-lg ring-4 ring-white sm:h-44 sm:w-44';

const tagline = t.hero.tagline;
const highlight = t.hero.taglineHighlight;
const hlIdx = tagline.indexOf(highlight);
const taglineBefore = hlIdx >= 0 ? tagline.slice(0, hlIdx) : tagline;
const taglineAfter = hlIdx >= 0 ? tagline.slice(hlIdx + highlight.length) : '';
---

<section class="relative mb-16 overflow-hidden rounded-3xl border border-[var(--color-line)] bg-white p-6 shadow-sm sm:p-10">
  <!-- decorative dot grid + soft green blob -->
  <div class="dot-grid pointer-events-none absolute inset-0 opacity-40"></div>
  <div
    class="pointer-events-none absolute -top-24 -right-20 h-64 w-64 rounded-full opacity-30 blur-3xl"
    style="background: radial-gradient(circle, var(--color-accent-soft) 0%, transparent 70%);"
  >
  </div>

  <div class="relative grid items-center gap-8 sm:grid-cols-[1fr_auto]">
    <div>
      <span
        class="mb-4 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent-soft)] px-3 py-1 text-xs font-semibold tracking-wide text-[var(--color-accent-dark)] uppercase"
      >
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--color-accent)]"></span>
        {t.hero.role}
      </span>
      <h1 class="mb-3 flex flex-wrap items-center gap-x-2 text-4xl font-extrabold tracking-tight sm:text-5xl">
        <span>{t.hero.name}</span>
        <img
          src="/freelance.jpg"
          alt=""
          aria-hidden="true"
          class="relative -top-1 inline-block h-14 w-auto sm:h-12"
        />
      </h1>

      <!-- mobile-only photo -->
      <div class="relative my-6 w-full max-w-[15rem] sm:hidden">
        <div
          class="absolute -inset-2 rounded-3xl opacity-50 blur-xl"
          style="background: linear-gradient(135deg, var(--color-accent-soft), var(--color-warm));"
        >
        </div>
        <div
          class="relative flex aspect-square w-full items-center justify-center overflow-hidden rounded-3xl bg-gradient-to-br from-emerald-100 to-amber-100 shadow-lg ring-4 ring-white"
        >
          <span class="text-5xl font-bold text-emerald-800/70">AR</span>
          <img
            src="/me.jpg"
            alt={t.hero.photoAlt}
            class="absolute inset-0 h-full w-full object-cover"
            onerror="this.style.display='none'"
          />
        </div>
      </div>

      <p class="mb-4 text-xl font-medium leading-snug text-[var(--color-ink)] sm:text-2xl">
        {taglineBefore}<span
          class="relative inline-block font-semibold underline decoration-[var(--color-ink)] decoration-[3px] underline-offset-4"
        >
          <svg
            class="absolute left-1/2 -translate-x-1/2 sm:hidden"
            style="top: -1.1em;"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M 9 16 L 9 3 M 3.5 8.5 L 9 3 L 14.5 8.5"
              stroke="#0a0a0a"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          {highlight}
        </span>{taglineAfter}
      </p>
      <p class="mb-6 max-w-prose text-base leading-relaxed text-[var(--color-muted)]">
        {t.hero.intro}
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href={`mailto:${t.contact.email}`}
          class="inline-flex items-center rounded-full bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[var(--color-accent-dark)]"
        >
          {t.hero.ctaPrimary}
        </a>
        <a
          href={t.contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-[#0a66c2] px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#004182]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45z"/>
          </svg>
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>

    <!-- desktop-only photo: right column -->
    <div class="relative mx-auto hidden sm:mx-0 sm:block">
      <div
        class="absolute -inset-2 rounded-3xl opacity-50 blur-xl"
        style="background: linear-gradient(135deg, var(--color-accent-soft), var(--color-warm));"
      >
      </div>
      <div class={photoClass}>
        <span class="text-3xl font-bold text-emerald-800/70">AR</span>
        <img
          src="/me.jpg"
          alt={t.hero.photoAlt}
          class="absolute inset-0 h-full w-full object-cover"
          onerror="this.style.display='none'"
        />
      </div>
    </div>
  </div>
</section>
